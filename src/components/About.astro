---
---

<section id="about" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Bio -->
      <div class="reveal">
        <div class="section-label">About</div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-8 leading-tight">
          I build web products<br/>
          <span class="gradient-text">that perform.</span>
        </h2>
        <div class="space-y-5 text-zinc-400 leading-relaxed text-lg">
          <p>
            I'm a Senior Frontend Engineer based in Berlin with over 11 years of experience
            building marketing websites and web applications for B2B SaaS, fintech, and
            enterprise companies across Europe.
          </p>
          <p>
            From legacy jQuery rewrites to full-stack Astro builds, I've shipped production
            software at every scale — solo, in distributed teams, and as a lead across
            multi-client agency environments.
          </p>
          <p>
            Today I run my own <span class="text-white font-medium">studio</span>, helping
            companies ditch slow, bloated websites and replace them with fast, CMS-driven
            platforms built on <span class="text-white font-medium">Astro</span> and
            <span class="text-white font-medium">Sanity</span>.
          </p>
        </div>

        <div class="flex flex-wrap gap-3 mt-8">
          <span class="tech-badge">Astro</span>
          <span class="tech-badge">Next.js</span>
          <span class="tech-badge">React</span>
          <span class="tech-badge">TypeScript</span>
          <span class="tech-badge">Sanity CMS</span>
          <span class="tech-badge">Tailwind CSS</span>
        </div>
      </div>

      <!-- Right: Fact cards -->
      <div class="reveal reveal-delay-2">
        <div class="grid grid-cols-2 gap-4">
          <div class="card p-6">
            <div class="text-4xl font-black gradient-text mb-2">11+</div>
            <div class="text-zinc-300 font-medium">Years building for the web</div>
            <div class="text-zinc-600 text-sm mt-1">2014 → Present</div>
          </div>
          <div class="card p-6">
            <div class="text-4xl font-black gradient-text mb-2">30+</div>
            <div class="text-zinc-300 font-medium">Projects shipped</div>
            <div class="text-zinc-600 text-sm mt-1">B2B SaaS & Enterprise</div>
          </div>
          <div class="card p-6">
            <div class="text-4xl font-black gradient-text mb-2">50%</div>
            <div class="text-zinc-300 font-medium">Faster load times</div>
            <div class="text-zinc-600 text-sm mt-1">Average across rebuilds</div>
          </div>
          <div class="card p-6">
            <div class="text-4xl font-black gradient-text mb-2">100</div>
            <div class="text-zinc-300 font-medium">Lighthouse score</div>
            <div class="text-zinc-600 text-sm mt-1">On every Astro build</div>
          </div>
        </div>

        <!-- Education -->
        <div class="card p-6 mt-4">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center flex-shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="1.5">
                <path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/>
                <path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
            </div>
            <div>
              <div class="text-white font-semibold">University of Bologna</div>
              <div class="text-zinc-400 text-sm mt-0.5">Computer Science & Software Engineering</div>
              <div class="text-zinc-600 text-xs mt-1">Villa Guastavillani · Graduated 2014</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
