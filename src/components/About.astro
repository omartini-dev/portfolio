---
---

<section id="about" class="py-24 px-6 relative overflow-hidden">
  <!-- Floating tech words canvas -->
  <canvas id="about-canvas" class="absolute inset-0 w-full h-full pointer-events-none" style="opacity:0.85;"></canvas>

  <div class="max-w-6xl mx-auto relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Bio -->
      <div class="reveal">
        <div class="section-label">About</div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-8 leading-tight">
          I build web products<br/>
          <span class="gradient-text">that perform.</span>
        </h2>
        <div class="space-y-5 text-zinc-400 leading-relaxed text-lg">
          <p>
            I'm a Senior Frontend Engineer based in Berlin with over 11 years of experience
            building marketing websites and web applications for B2B SaaS, fintech, and
            enterprise companies across Europe.
          </p>
          <p>
            From legacy jQuery rewrites to full-stack headless builds, I've shipped production
            software at every scale — solo, in distributed teams, and as a lead across
            multi-client agency environments.
          </p>
          <p>
            Today I run my own <span class="text-white font-medium">studio</span>, helping
            companies replace slow, bloated websites with fast, CMS-driven platforms.
          </p>
        </div>

        <div class="flex flex-wrap gap-3 mt-8">
          <span class="tech-badge">Astro</span>
          <span class="tech-badge">Next.js</span>
          <span class="tech-badge">Svelte</span>
          <span class="tech-badge">React</span>
          <span class="tech-badge">TypeScript</span>
          <span class="tech-badge">Sanity CMS</span>
          <span class="tech-badge">Tailwind CSS</span>
        </div>
      </div>

      <!-- Right: Fact cards -->
      <div class="reveal reveal-delay-2">
        <div class="grid grid-cols-2 gap-4">
          <div class="card p-6">
            <div class="text-4xl font-black gradient-text mb-2">11+</div>
            <div class="text-zinc-300 font-medium">Years building for the web</div>
            <div class="text-zinc-600 text-sm mt-1">2014 → Present</div>
          </div>
          <div class="card p-6">
            <div class="text-4xl font-black gradient-text mb-2">30+</div>
            <div class="text-zinc-300 font-medium">Projects shipped</div>
            <div class="text-zinc-600 text-sm mt-1">B2B SaaS & Enterprise</div>
          </div>
          <div class="card p-6">
            <div class="text-4xl font-black gradient-text mb-2">50%</div>
            <div class="text-zinc-300 font-medium">Faster load times</div>
            <div class="text-zinc-600 text-sm mt-1">Average across rebuilds</div>
          </div>
          <div class="card p-6">
            <div class="text-4xl font-black gradient-text mb-2">100</div>
            <div class="text-zinc-300 font-medium">Lighthouse score</div>
            <div class="text-zinc-600 text-sm mt-1">On every optimized build</div>
          </div>
        </div>

        <!-- Education -->
        <div class="card p-6 mt-4">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center flex-shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="1.5">
                <path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/>
                <path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
            </div>
            <div>
              <div class="text-white font-semibold">University of Bologna</div>
              <div class="text-zinc-400 text-sm mt-0.5">Computer Science & Software Engineering</div>
              <div class="text-zinc-600 text-xs mt-1">Villa Guastavillani · Graduated 2014</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const canvas = document.getElementById('about-canvas') as HTMLCanvasElement | null;
  if (!canvas) throw new Error('no canvas');
  const ctx = canvas.getContext('2d')!;

  const resize = () => {
    canvas.width  = canvas.clientWidth  * devicePixelRatio;
    canvas.height = canvas.clientHeight * devicePixelRatio;
    ctx.scale(devicePixelRatio, devicePixelRatio);
  };
  resize();
  window.addEventListener('resize', resize);

  const WORDS = [
    'HTML', 'CSS', 'JavaScript', 'TypeScript', 'React', 'Next.js',
    'Astro', 'Svelte', 'Vue', 'Node.js', 'Tailwind', 'Sanity',
    'GraphQL', 'REST', 'Vite', 'Webpack', 'Git', 'Vercel',
    'SSG', 'SSR', 'ISR', 'a11y', 'SEO', 'LCP',
  ];

  const W = () => canvas.clientWidth;
  const H = () => canvas.clientHeight;

  const particles = WORDS.map((word, i) => ({
    word,
    x: Math.random() * W(),
    y: H() + Math.random() * H(),
    speed: 0.3 + Math.random() * 0.35,
    opacity: 0.12 + Math.random() * 0.18,
    size: 12 + Math.random() * 8,
    phase: (i / WORDS.length) * Math.PI * 2,
  }));

  const draw = () => {
    requestAnimationFrame(draw);
    ctx.clearRect(0, 0, W(), H());
    ctx.font = `500 13px 'JetBrains Mono', monospace`;

    particles.forEach(p => {
      p.y -= p.speed;
      p.x += Math.sin(p.y * 0.008 + p.phase) * 0.4;

      if (p.y < -30) {
        p.y = H() + 20;
        p.x = Math.random() * W();
      }

      // fade in near top, fade out at very top
      const fadeTop = Math.min(p.y / 80, 1);
      const alpha = p.opacity * fadeTop;

      const colors = ['#818cf8', '#c084fc', '#67e8f9', '#a5f3fc'];
      ctx.globalAlpha = alpha;
      ctx.fillStyle = colors[Math.floor(p.phase * 4 / (Math.PI * 2)) % colors.length];
      ctx.font = `600 ${p.size}px 'JetBrains Mono', monospace`;
      ctx.fillText(p.word, p.x, p.y);
    });

    ctx.globalAlpha = 1;
  };
  draw();
</script>
