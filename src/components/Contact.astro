<script>
  const canvas = document.getElementById('contact-canvas') as HTMLCanvasElement | null;
  if (!canvas) throw new Error('no canvas');
  const ctx = canvas.getContext('2d')!;

  const resize = () => {
    canvas.width  = canvas.clientWidth  * devicePixelRatio;
    canvas.height = canvas.clientHeight * devicePixelRatio;
    ctx.scale(devicePixelRatio, devicePixelRatio);
  };
  resize();
  window.addEventListener('resize', resize);

  const W = () => canvas.clientWidth;
  const H = () => canvas.clientHeight;

  // Rings that expand outward from center
  const RING_COLORS = ['99,102,241', '139,92,246', '34,211,238'];
  const rings: { r: number; alpha: number; speed: number; colorIdx: number }[] = [];
  const RING_INTERVAL = 1200;
  let colorIdx = 0;

  const spawnRing = () => {
    rings.push({ r: 30, alpha: 0.5, speed: 1.1, colorIdx: colorIdx % RING_COLORS.length });
    colorIdx++;
  };
  spawnRing(); spawnRing();
  setInterval(spawnRing, RING_INTERVAL);

  const draw = () => {
    requestAnimationFrame(draw);
    ctx.clearRect(0, 0, W(), H());

    const cx = W() / 2;
    const cy = H() * 0.38;

    for (let i = rings.length - 1; i >= 0; i--) {
      const ring = rings[i];
      ring.r    += ring.speed;
      ring.alpha -= 0.003;

      if (ring.alpha <= 0) { rings.splice(i, 1); continue; }

      ctx.beginPath();
      ctx.arc(cx, cy, ring.r, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(${RING_COLORS[ring.colorIdx]},${ring.alpha})`;
      ctx.lineWidth = 2;
      ctx.stroke();
    }
  };
  draw();
</script>
