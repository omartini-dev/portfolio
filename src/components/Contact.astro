---
---

<section id="contact" class="py-24 px-6 bg-[#0c0c0e] relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px]"
      style="background: radial-gradient(ellipse, rgba(99,102,241,0.1) 0%, transparent 70%);">
    </div>
  </div>

  <div class="max-w-3xl mx-auto text-center relative">
    <div class="reveal">
      <div class="section-label mb-4">Get In Touch</div>
      <h2 class="text-4xl md:text-6xl font-black text-white leading-tight mb-6">
        Let's build something
        <span class="gradient-text"> fast.</span>
      </h2>
      <p class="text-zinc-400 text-xl leading-relaxed mb-12 max-w-xl mx-auto">
        Whether you need a new marketing site, a Sanity migration, or a
        performance audit — I'm ready to talk.
      </p>

      <a
        href="mailto:osvaldo.martini.dev@gmail.com"
        class="inline-flex items-center gap-3 px-8 py-4 bg-indigo-500 hover:bg-indigo-400 text-white text-lg font-bold rounded-xl transition-all duration-200 hover:-translate-y-1 hover:shadow-2xl hover:shadow-indigo-500/30 mb-12"
      >
        osvaldo.martini.dev@gmail.com
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M3 15L15 3M15 3H7M15 3V11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <!-- Contact cards -->
    <div class="reveal reveal-delay-2 grid grid-cols-1 md:grid-cols-3 gap-4 text-left">
      <a
        href="mailto:osvaldo.martini.dev@gmail.com"
        class="card p-5 hover:-translate-y-1 transition-transform duration-200 group"
      >
        <div class="w-9 h-9 rounded-lg bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-indigo-400 mb-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M2 7l10 7 10-7"/>
          </svg>
        </div>
        <div class="text-white text-sm font-semibold mb-1">Email</div>
        <div class="text-zinc-500 text-xs group-hover:text-zinc-400 transition-colors">osvaldo.martini.dev@gmail.com</div>
      </a>

      <a
        href="https://linkedin.com/in/osvaldo-martini/"
        target="_blank"
        rel="noopener"
        class="card p-5 hover:-translate-y-1 transition-transform duration-200 group"
      >
        <div class="w-9 h-9 rounded-lg bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 mb-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </div>
        <div class="text-white text-sm font-semibold mb-1">LinkedIn</div>
        <div class="text-zinc-500 text-xs group-hover:text-zinc-400 transition-colors">osvaldo-martini</div>
      </a>

      <a
        href="https://github.com/omartini-dev"
        target="_blank"
        rel="noopener"
        class="card p-5 hover:-translate-y-1 transition-transform duration-200 group"
      >
        <div class="w-9 h-9 rounded-lg bg-zinc-700/50 border border-zinc-600/30 flex items-center justify-center text-zinc-400 mb-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.49.5.09.68-.22.68-.48v-1.69c-2.78.6-3.37-1.34-3.37-1.34-.45-1.15-1.11-1.46-1.11-1.46-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.56 9.56 0 0112 6.8c.85 0 1.71.12 2.51.34 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.93.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10.01 10.01 0 0022 12c0-5.52-4.48-10-10-10z"/>
          </svg>
        </div>
        <div class="text-white text-sm font-semibold mb-1">GitHub</div>
        <div class="text-zinc-500 text-xs group-hover:text-zinc-400 transition-colors">omartini-dev</div>
      </a>
    </div>

    <div class="reveal reveal-delay-3 mt-8 text-zinc-600 text-sm flex items-center justify-center gap-2">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
        <circle cx="12" cy="9" r="2.5"/>
      </svg>
      Based in Berlin, Germany · Open to remote projects worldwide
    </div>
  </div>
</section>
