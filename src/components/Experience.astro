---
const jobs = [
  {
    num: '01',
    company: 'Webstacks',
    role: 'Senior Frontend Engineer',
    period: 'Sep 2020 – Present',
    duration: '4+ years',
    type: 'Agency · Remote',
    color: '#6366f1',
    tagline: 'WEBSTACKS · SENIOR FRONTEND ENGINEER · REMOTE · 2020–PRESENT',
    highlights: [
      'Delivered 10+ B2B SaaS marketing websites, contributing to 15–30% conversion rate improvements via performance and UX optimization.',
      'Reduced average page load time by 30–50% using SSR optimization, code splitting, and asset strategies.',
      'Led frontend architecture for reusable component systems, cutting new page dev time by 25–35%.',
      'Refined Core Web Vitals — LCP under 2.5s on key pages with measurable SEO ranking lifts.',
    ],
    stack: ['React', 'Next.js', 'Astro', 'TypeScript', 'Sanity', 'Tailwind CSS', 'Vercel'],
  },
  {
    num: '02',
    company: 'Reply',
    role: 'Frontend Developer',
    period: 'Aug 2018 – Sep 2020',
    duration: '2 years',
    type: 'Consultancy · Milan',
    color: '#8b5cf6',
    tagline: 'REPLY · FRONTEND DEVELOPER · MILAN · 2018–2020',
    highlights: [
      'Built enterprise frontend apps for finance, telecom, and industrial clients — serving 50,000+ users per platform.',
      'Developed reusable component libraries in React and Vue.js across 8+ enterprise applications.',
      'Integrated REST APIs handling 10k–100k+ daily requests depending on client system.',
      'Led migration of legacy jQuery systems to modern frameworks, reducing maintenance effort by 40%.',
    ],
    stack: ['React', 'Vue.js', 'JavaScript', 'REST APIs', 'Sass', 'Webpack'],
  },
  {
    num: '03',
    company: 'Alten Italia',
    role: 'Web Developer',
    period: 'Oct 2014 – Aug 2018',
    duration: '4 years',
    type: 'Engineering Consultancy · Italy',
    color: '#22d3ee',
    tagline: 'ALTEN ITALIA · WEB DEVELOPER · ITALY · 2014–2018',
    highlights: [
      'Built responsive UI components for enterprise portals serving 10,000–30,000+ users per client.',
      'Delivered financial intelligence platforms using Next.js and data-driven page architectures.',
      'Assisted migration of legacy frontend systems, improving maintainability and long-term stability.',
      'Decreased recurring UI bugs by 20% through structured fixes and regression testing.',
    ],
    stack: ['JavaScript', 'jQuery', 'HTML5', 'CSS3', 'Next.js', 'Bootstrap'],
  },
];
---

<!-- Section is 300vh so user scrolls through 3 scenes -->
<section id="experience" class="relative bg-black exp-section" style="height: 300vh;">

  <!-- Sticky viewport: the 3D stage stays in view while user scrolls -->
  <div class="sticky top-0 h-screen overflow-hidden">

    <!-- Three.js canvas fills the entire stage -->
    <canvas id="three-exp" class="absolute inset-0 w-full h-full" style="z-index:0;"></canvas>

    <!-- Cinematic letterbox bars -->
    <div class="absolute top-0 left-0 right-0 z-20 pointer-events-none exp-letterbox-t" style="height:8vh;"></div>
    <div class="absolute bottom-0 left-0 right-0 z-20 pointer-events-none exp-letterbox-b" style="height:8vh;"></div>

    <!-- Top-left label -->
    <div class="absolute z-30 flex items-center gap-4" style="top: 3vh; left: 2rem;">
      <div class="section-label mb-0">Experience</div>
      <div class="h-px flex-1 w-12" style="background: rgba(99,102,241,0.4);"></div>
    </div>

    <!-- Scene counter (film-style, top right) -->
    <div id="scene-counter" class="absolute z-30 font-mono text-xs text-zinc-600 tracking-[0.3em]" style="top: 3vh; right: 2rem;">
      01 / 03
    </div>

    <!-- Progress indicator (right side, vertical) -->
    <div class="absolute right-6 top-1/2 -translate-y-1/2 z-30 flex flex-col items-center gap-4">
      {jobs.map((job, i) => (
        <div
          class="exp-dot rounded-full transition-all duration-500 cursor-default"
          data-idx={i}
          data-color={job.color}
          style={`width: 4px; height: ${i === 0 ? '28px' : '8px'}; background: ${i === 0 ? job.color : '#3f3f46'};`}
        ></div>
      ))}
    </div>

    <!-- Scene panels: one per job, shown/hidden by JS -->
    {jobs.map((job, i) => (
      <div
        class="exp-scene absolute inset-0 flex items-center z-10"
        data-idx={i}
        style={`opacity: ${i === 0 ? 1 : 0}; transform: translateY(${i === 0 ? 0 : 30}px); transition: opacity 0.7s ease, transform 0.7s ease; pointer-events: ${i === 0 ? 'auto' : 'none'};`}
      >
        <div class="w-full max-w-6xl mx-auto px-8 md:px-16 grid grid-cols-1 lg:grid-cols-3 gap-8 items-center">

          <!-- Content: spans 2 cols -->
          <div class="lg:col-span-2">
            <!-- Type label -->
            <div class="flex items-center gap-3 mb-6">
              <div class="w-8 h-px" style={`background: ${job.color};`}></div>
              <span class="text-xs uppercase tracking-[0.25em] font-semibold" style={`color: ${job.color};`}>{job.type}</span>
            </div>

            <!-- Company name — huge -->
            <h2 class="font-black leading-none mb-3" style="font-size: clamp(2.5rem, 8vw, 6rem);">
              <span class="text-white">{job.company}</span>
            </h2>

            <div class="flex items-baseline gap-4 mb-8">
              <span class="text-xl md:text-2xl text-zinc-300 font-medium">{job.role}</span>
              <span class="text-zinc-600 font-mono text-sm">{job.period}</span>
            </div>

            <!-- Highlights -->
            <div class="space-y-4 mb-8">
              {job.highlights.map((h, hi) => (
                <div
                  class="flex gap-4 items-start exp-highlight"
                  style={`animation-delay: ${hi * 0.08}s;`}
                >
                  <div class="flex-shrink-0 mt-2">
                    <div class="w-4 h-4 rounded-full flex items-center justify-center" style={`background: ${job.color}20;`}>
                      <div class="w-1.5 h-1.5 rounded-full" style={`background: ${job.color};`}></div>
                    </div>
                  </div>
                  <p class="text-zinc-300 leading-relaxed">{h}</p>
                </div>
              ))}
            </div>

            <!-- Stack -->
            <div class="flex flex-wrap gap-2">
              {job.stack.map(t => (
                <span class="tech-badge-glow">{t}</span>
              ))}
            </div>
          </div>

          <!-- Right col: large scene number -->
          <div class="hidden lg:flex flex-col items-end justify-center gap-2">
            <div class="font-black text-right leading-none select-none" style={`font-size: clamp(5rem, 12vw, 10rem); color: ${job.color}; opacity: 0.08;`}>
              {job.num}
            </div>
            <div class="px-4 py-2 rounded-full border text-xs font-semibold font-mono" style={`color: ${job.color}; border-color: ${job.color}30; background: ${job.color}10;`}>
              {job.duration}
            </div>
          </div>

        </div>
      </div>
    ))}

    <!-- Bottom marquee (film-style ticker) -->
    <div class="absolute z-30 overflow-hidden w-full" style="bottom: 3vh;">
      <div class="marquee-wrap">
        <div id="scene-tagline" class="marquee-inner font-mono text-xs tracking-[0.25em] text-zinc-700 whitespace-nowrap">
          ━━━ WEBSTACKS · SENIOR FRONTEND ENGINEER · REMOTE · 2020–PRESENT ━━━ WEBSTACKS · SENIOR FRONTEND ENGINEER · REMOTE · 2020–PRESENT ━━━
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .marquee-wrap { overflow: hidden; }
  .marquee-inner { display: inline-block; animation: marqueeScroll 22s linear infinite; }
  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .exp-letterbox-t { background: linear-gradient(to bottom, var(--bg) 60%, transparent); }
  .exp-letterbox-b { background: linear-gradient(to top,   var(--bg) 60%, transparent); }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('three-exp') as HTMLCanvasElement | null;
  if (!canvas) throw new Error('no canvas');

  // ── Renderer ─────────────────────────────────────
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
  renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
  renderer.setClearColor(0x000000);

  // ── Scene ────────────────────────────────────────
  const scene = new THREE.Scene();
  scene.fog = new THREE.FogExp2(0x000000, 0.028);

  // ── Camera ───────────────────────────────────────
  const camera = new THREE.PerspectiveCamera(62, 1, 0.1, 200);
  camera.position.set(0, 1.5, 52);

  const resize = () => {
    const W = canvas.clientWidth, H = canvas.clientHeight;
    camera.aspect = W / H;
    camera.updateProjectionMatrix();
    renderer.setSize(W, H);
  };
  resize();
  window.addEventListener('resize', resize);

  // ── Floor grid ───────────────────────────────────
  const grid = new THREE.GridHelper(200, 50, 0x1a1a3a, 0x0d0d1e);
  grid.position.y = -5;
  scene.add(grid);

  // ── Corridor depth lines ─────────────────────────
  const addLine = (x: number, y: number, color: number) => {
    const pts = [new THREE.Vector3(x, y, -60), new THREE.Vector3(x, y, 60)];
    scene.add(new THREE.Line(
      new THREE.BufferGeometry().setFromPoints(pts),
      new THREE.LineBasicMaterial({ color, transparent: true, opacity: 0.2 })
    ));
  };
  [-12,-8,-4,4,8,12].forEach(x => addLine(x, -5, 0x1e1e3f));
  [-12,-8,-4,4,8,12].forEach(x => addLine(x,  5, 0x1e1e3f));

  // ── Movie frames (3, one per job scene) ──────────
  const FRAME_DEFS = [
    { z: 22,  color: new THREE.Color(0x6366f1) },
    { z:  0,  color: new THREE.Color(0x8b5cf6) },
    { z: -22, color: new THREE.Color(0x22d3ee) },
  ];

  interface FrameObj { group: THREE.Group; light: THREE.PointLight; }
  const frames: FrameObj[] = FRAME_DEFS.map(fd => {
    const group = new THREE.Group();
    group.position.z = fd.z;

    const FW = 22, FH = 12;
    // Outer rectangle
    const corners = [
      new THREE.Vector3(-FW/2, -FH/2, 0),
      new THREE.Vector3( FW/2, -FH/2, 0),
      new THREE.Vector3( FW/2,  FH/2, 0),
      new THREE.Vector3(-FW/2,  FH/2, 0),
      new THREE.Vector3(-FW/2, -FH/2, 0),
    ];
    group.add(new THREE.Line(
      new THREE.BufferGeometry().setFromPoints(corners),
      new THREE.LineBasicMaterial({ color: fd.color, transparent: true, opacity: 0.55 })
    ));

    // Horizontal scan lines (cinematic feel)
    for (let row = -4; row <= 4; row++) {
      const y = row * (FH / 9);
      group.add(new THREE.Line(
        new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(-FW/2, y, 0), new THREE.Vector3(FW/2, y, 0)]),
        new THREE.LineBasicMaterial({ color: fd.color, transparent: true, opacity: 0.03 })
      ));
    }

    // Corner bracket accents
    const bSize = 1.8;
    const brackets: [number, number, number, number][] = [
      [-FW/2, -FH/2, 1, 1], [FW/2, -FH/2, -1, 1], [-FW/2, FH/2, 1, -1], [FW/2, FH/2, -1, -1]
    ];
    brackets.forEach(([cx, cy, dx, dy]) => {
      group.add(new THREE.Line(
        new THREE.BufferGeometry().setFromPoints([
          new THREE.Vector3(cx + dx * bSize, cy, 0),
          new THREE.Vector3(cx, cy, 0),
          new THREE.Vector3(cx, cy + dy * bSize, 0),
        ]),
        new THREE.LineBasicMaterial({ color: fd.color, transparent: true, opacity: 1 })
      ));
    });

    // Point light (starts off)
    const light = new THREE.PointLight(fd.color, 0, 35);
    light.position.set(0, 0, 8);
    group.add(light);

    // Frame particles
    const pN = 120;
    const pPos = new Float32Array(pN * 3);
    for (let i = 0; i < pN; i++) {
      pPos[i*3]   = (Math.random() - 0.5) * FW * 1.2;
      pPos[i*3+1] = (Math.random() - 0.5) * FH * 1.2;
      pPos[i*3+2] = (Math.random() - 0.5) * 10;
    }
    const pGeo = new THREE.BufferGeometry();
    pGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
    group.add(new THREE.Points(pGeo, new THREE.PointsMaterial({ color: fd.color, size: 0.05, transparent: true, opacity: 0.35 })));

    scene.add(group);
    return { group, light };
  });

  // ── Corridor particles (stream toward camera) ────
  const CP_N = 700;
  const cpPos = new Float32Array(CP_N * 3);
  for (let i = 0; i < CP_N; i++) {
    cpPos[i*3]   = (Math.random() - 0.5) * 28;
    cpPos[i*3+1] = (Math.random() - 0.5) * 16;
    cpPos[i*3+2] = Math.random() * 90 - 40;
  }
  const cpGeo = new THREE.BufferGeometry();
  cpGeo.setAttribute('position', new THREE.BufferAttribute(cpPos, 3));
  const corridorPts = new THREE.Points(
    cpGeo,
    new THREE.PointsMaterial({ color: 0x2d2d5a, size: 0.07, transparent: true, opacity: 0.45 })
  );
  scene.add(corridorPts);

  // ── Ambient light ────────────────────────────────
  scene.add(new THREE.AmbientLight(0x080814, 4));

  // ── UI references ────────────────────────────────
  const expSection  = document.getElementById('experience');
  const scenePanels = Array.from(document.querySelectorAll<HTMLElement>('.exp-scene'));
  const expDots     = Array.from(document.querySelectorAll<HTMLElement>('.exp-dot'));
  const sceneCounter = document.getElementById('scene-counter');
  const taglineEl   = document.getElementById('scene-tagline');

  const TAGLINES = [
    '━━━ WEBSTACKS · SENIOR FRONTEND ENGINEER · REMOTE · 2020–PRESENT ━━━ WEBSTACKS · SENIOR FRONTEND ENGINEER · REMOTE · 2020–PRESENT ━━━',
    '━━━ REPLY · FRONTEND DEVELOPER · MILAN · 2018–2020 ━━━ REPLY · FRONTEND DEVELOPER · MILAN · 2018–2020 ━━━',
    '━━━ ALTEN ITALIA · WEB DEVELOPER · ITALY · 2014–2018 ━━━ ALTEN ITALIA · WEB DEVELOPER · ITALY · 2014–2018 ━━━',
  ];
  const DOT_COLORS = ['#6366f1', '#8b5cf6', '#22d3ee'];

  let currentScene = -1;
  const activateScene = (idx: number) => {
    if (idx === currentScene) return;
    currentScene = idx;

    scenePanels.forEach((p, i) => {
      const active = i === idx;
      p.style.opacity = active ? '1' : '0';
      p.style.transform = active ? 'translateY(0px)' : `translateY(${i > idx ? '30px' : '-30px'})`;
      p.style.pointerEvents = active ? 'auto' : 'none';
    });

    expDots.forEach((d, i) => {
      d.style.height  = i === idx ? '28px' : '8px';
      d.style.background = i === idx ? DOT_COLORS[i] : '#3f3f46';
    });

    if (sceneCounter) sceneCounter.textContent = `0${idx + 1} / 03`;
    if (taglineEl) taglineEl.textContent = TAGLINES[idx];

    // Fade in active frame's light, out others
    frames.forEach((f, i) => { f.light.intensity = i === idx ? 7 : 0; });
  };

  // Target camera Z for each scene (camera travels forward)
  const CAM_Z_FOR_SCENE = [40, 16, -8];
  let targetCamZ = 52;

  window.addEventListener('scroll', () => {
    if (!expSection) return;
    const scrolled = -(expSection.getBoundingClientRect().top);
    const total = expSection.offsetHeight - window.innerHeight;
    const progress = Math.max(0, Math.min(1, scrolled / total));
    targetCamZ = 52 - progress * 70;
    activateScene(Math.min(2, Math.floor(progress * 3)));
  });

  activateScene(0);

  // ── Theme-aware renderer color ────────────────────
  const applyExpTheme = (isLight: boolean) => {
    const bg = isLight ? 0xf5f5fa : 0x000000;
    renderer.setClearColor(bg);
    (scene.fog as THREE.FogExp2).color.setHex(bg);
  };
  applyExpTheme(document.documentElement.dataset.theme === 'light');
  window.addEventListener('themechange', (e: Event) => {
    applyExpTheme((e as CustomEvent<{theme:string}>).detail.theme === 'light');
  });

  // ── Animate ──────────────────────────────────────
  let t = 0;
  const animate = () => {
    requestAnimationFrame(animate);
    t += 0.007;

    // Camera glides through corridor
    camera.position.z += (targetCamZ - camera.position.z) * 0.055;
    camera.position.x = Math.sin(t * 0.12) * 0.5;
    camera.position.y = 1.5 + Math.sin(t * 0.09) * 0.25;
    camera.lookAt(0, 0, camera.position.z - 25);

    // Gentle frame drift
    frames.forEach((f, i) => {
      f.group.rotation.y = Math.sin(t * 0.18 + i) * 0.015;
      f.group.rotation.x = Math.sin(t * 0.13 + i) * 0.008;
    });

    // Corridor particles stream toward viewer
    const arr = cpGeo.attributes.position.array as Float32Array;
    for (let i = 0; i < CP_N; i++) {
      arr[i*3 + 2] += 0.025;
      if (arr[i*3 + 2] > 60) arr[i*3 + 2] = -40;
    }
    cpGeo.attributes.position.needsUpdate = true;

    renderer.render(scene, camera);
  };
  animate();
</script>
