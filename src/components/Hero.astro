    <div class="grid grid-cols-1 lg:grid-cols-5 gap-16 items-center">

      <!-- Left -->
      <div class="lg:col-span-3 space-y-8">
        <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full border border-emerald-500/20 bg-emerald-500/5 text-emerald-400 text-sm font-medium" style="animation: fadeUp 0.6s ease-out both;">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          Available for new projects
        </div>

        <div style="animation: fadeUp 0.6s ease-out 0.12s both;">
          <h1 class="font-black leading-none tracking-tight">
            <span class="block text-5xl md:text-7xl xl:text-8xl text-white">Osvaldo</span>
            <span class="block text-5xl md:text-7xl xl:text-8xl gradient-text-animated">Martini</span>
          </h1>
          <p class="mt-5 text-lg md:text-xl text-zinc-400 font-medium">Senior Frontend Engineer & Studio Founder</p>
        </div>

        <p class="text-zinc-400 text-lg leading-relaxed max-w-xl" style="animation: fadeUp 0.6s ease-out 0.24s both;">
          11+ years building high-performance marketing websites for B2B SaaS companies.
          Specializing in <span class="text-white font-medium">Astro</span>,
          <span class="text-white font-medium">Next.js</span>, and
          <span class="text-white font-medium">headless CMS</span> architectures that score 100 on Lighthouse.
        </p>

        <div class="flex flex-wrap gap-4" style="animation: fadeUp 0.6s ease-out 0.36s both;">
          <a href="#work" class="btn-primary text-base">
            View My Work
