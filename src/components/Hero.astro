        </div>

        <div class="flex flex-wrap items-center gap-6 text-sm text-zinc-500" style="animation: fadeUp 0.6s ease-out 0.48s both;">
          <a href="mailto:osvaldo.martini.dev@gmail.com" class="hover:text-zinc-300 transition-colors flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>
            Email
          </a>
          <a href="https://linkedin.com/in/osvaldo-martini/" target="_blank" rel="noopener" class="hover:text-zinc-300 transition-colors flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
            LinkedIn
          </a>
          <a href="https://github.com/omartini-dev" target="_blank" rel="noopener" class="hover:text-zinc-300 transition-colors flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.49.5.09.68-.22.68-.48v-1.69c-2.78.6-3.37-1.34-3.37-1.34-.45-1.15-1.11-1.46-1.11-1.46-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.56 9.56 0 0112 6.8c.85 0 1.71.12 2.51.34 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.93.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10.01 10.01 0 0022 12c0-5.52-4.48-10-10-10z"/></svg>
            GitHub
          </a>
          <span class="flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            Berlin, Germany
          </span>
        </div>
      </div>

      <!-- Right: Terminal -->
      <div class="lg:col-span-2 hidden lg:block" style="animation: floatShape 8s ease-in-out infinite; --rot:0deg;">
        <div class="terminal relative overflow-hidden">
          <div class="absolute inset-0 pointer-events-none z-10"
            style="background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.025) 50%, transparent 60%); animation: shimmer 5s ease infinite;">
          </div>
          <div class="terminal-header">
            <div class="terminal-dot" style="background:#ff5f57"></div>
            <div class="terminal-dot" style="background:#febc2e"></div>
            <div class="terminal-dot" style="background:#28c840"></div>
            <span class="ml-3 text-xs text-zinc-500 font-mono">astro build</span>
          </div>
          <div class="terminal-body">
            <div><span class="t-prompt">$</span> <span class="t-cmd">astro build</span></div>
            <div class="t-dim">▶ Running build jobs...</div>
            <br/>
            <div><span class="t-success">✔</span> <span class="t-info">Generating 47 pages</span>&nbsp;&nbsp;<span class="t-dim">0.4s</span></div>
            <div><span class="t-success">✔</span> <span class="t-info">Optimizing assets</span>&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-dim">0.2s</span></div>
            <div><span class="t-success">✔</span> <span class="t-info">TypeScript: strict</span>&nbsp;&nbsp;&nbsp;<span class="t-dim">pass</span></div>
            <div><span class="t-success">✔</span> <span class="t-info">Bundle: 11KB total</span>&nbsp;&nbsp;<span class="t-dim">↓ 94%</span></div>
            <br/>
            <div class="t-dim">── Lighthouse ─────────────</div>
            <div><span class="t-score">Performance </span>&nbsp;&nbsp;<span class="t-success">100</span>&nbsp;<span class="t-success">██████████</span></div>
            <div><span class="t-score">Accessibility</span>&nbsp;<span class="t-success">100</span>&nbsp;<span class="t-success">██████████</span></div>
            <div><span class="t-score">Best Practice</span>&nbsp;<span class="t-success">100</span>&nbsp;<span class="t-success">██████████</span></div>
            <div><span class="t-score">SEO&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>&nbsp;<span class="t-success">100</span>&nbsp;<span class="t-success">██████████</span></div>
            <br/>
            <div><span class="t-highlight">LCP </span>&nbsp;&nbsp;<span class="t-cmd">0.31s</span>&nbsp;&nbsp;<span class="t-success">●</span></div>
            <div><span class="t-highlight">FID </span>&nbsp;&nbsp;<span class="t-cmd">0ms  </span>&nbsp;&nbsp;<span class="t-success">●</span></div>
            <div><span class="t-highlight">CLS </span>&nbsp;&nbsp;<span class="t-cmd">0.00 </span>&nbsp;&nbsp;<span class="t-success">●</span></div>
            <br/>
            <div class="t-success">✓ Build complete in 0.8s<span style="animation: blink 1.2s step-end infinite; color:#6366f1">_</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Animated stats -->
    <div class="mt-20 pt-8 border-t border-zinc-800/60 grid grid-cols-2 md:grid-cols-4 gap-8" style="animation: fadeUp 0.6s ease-out 0.6s both;">
      <div><div class="text-3xl font-black text-white" data-count="11" data-suffix="+">0+</div><div class="text-sm text-zinc-500 mt-1">Years Experience</div></div>
      <div><div class="text-3xl font-black text-white" data-count="30" data-suffix="+">0+</div><div class="text-sm text-zinc-500 mt-1">Projects Delivered</div></div>
      <div><div class="text-3xl font-black text-white" data-count="100" data-suffix="">0</div><div class="text-sm text-zinc-500 mt-1">Lighthouse Scores</div></div>
      <div><div class="text-3xl font-black text-white" data-count="3" data-suffix="">0</div><div class="text-sm text-zinc-500 mt-1">Industries Served</div></div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
  @keyframes blink  { 0%,100% { opacity:1; } 50% { opacity:0; } }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('three-hero') as HTMLCanvasElement | null;
  if (!canvas) throw new Error('no canvas');

  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setPixelRatio(Math.min(devicePixelRatio, 2));

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(55, 1, 0.1, 200);
  camera.position.set(0, 0, 14);

  const resize = () => {
    const W = canvas.clientWidth, H = canvas.clientHeight;
    camera.aspect = W / H;
    camera.updateProjectionMatrix();
    renderer.setSize(W, H);
  };
  resize();
  window.addEventListener('resize', resize);

  // ── Main icosahedron group ──────────────────────
  const icoGeo = new THREE.IcosahedronGeometry(2.8, 1);
  const icoGroup = new THREE.Group();

  icoGroup.add(new THREE.Mesh(
    icoGeo,
    new THREE.MeshPhongMaterial({ color: 0x312e81, transparent: true, opacity: 0.05, side: THREE.DoubleSide })
  ));
  icoGroup.add(new THREE.LineSegments(
    new THREE.EdgesGeometry(icoGeo),
    new THREE.LineBasicMaterial({ color: 0x6366f1, transparent: true, opacity: 0.75 })
  ));
  scene.add(icoGroup);

  // ── Orbital rings ───────────────────────────────
  const ring = (r: number, tube: number, color: number, opacity: number, rx: number, ry: number) => {
    const m = new THREE.Mesh(
      new THREE.TorusGeometry(r, tube, 8, 120),
      new THREE.MeshBasicMaterial({ color, transparent: true, opacity })
    );
    m.rotation.set(rx, ry, 0);
    scene.add(m);
    return m;
  };
  const r1 = ring(5.2, 0.014, 0x8b5cf6, 0.35, Math.PI * 0.2,  0);
  const r2 = ring(7.4, 0.009, 0x22d3ee, 0.18, Math.PI * 0.55, Math.PI * 0.25);
  const r3 = ring(4.0, 0.017, 0x6366f1, 0.22, Math.PI * 0.75, Math.PI * 0.1);

  // ── Satellite objects ───────────────────────────
  const SAT = [
    { G: new THREE.OctahedronGeometry(0.45),      c: 0xa855f7, r: 5.2,  s: 0.9,  p: 0    },
    { G: new THREE.IcosahedronGeometry(0.32, 0),  c: 0x22d3ee, r: 6.8,  s: 0.55, p: 2.1  },
    { G: new THREE.TetrahedronGeometry(0.42),      c: 0x818cf8, r: 4.6,  s: 1.3,  p: 1.2  },
    { G: new THREE.BoxGeometry(0.38, 0.38, 0.38), c: 0x67e8f9, r: 7.2,  s: 0.35, p: 3.8  },
    { G: new THREE.OctahedronGeometry(0.28),       c: 0xf0abfc, r: 5.6,  s: 0.75, p: 5.1  },
    { G: new THREE.IcosahedronGeometry(0.22, 0),  c: 0x6366f1, r: 4.0,  s: 1.8,  p: 2.8  },
  ];

  const sats = SAT.map(d => {
    const useEdge = Math.random() > 0.5;
    let mesh: THREE.Object3D;
    if (useEdge) {
      mesh = new THREE.LineSegments(
        new THREE.EdgesGeometry(d.G),
        new THREE.LineBasicMaterial({ color: d.c, transparent: true, opacity: 0.8 })
      );
    } else {
      mesh = new THREE.Mesh(d.G,
        new THREE.MeshPhongMaterial({ color: d.c, emissive: d.c, emissiveIntensity: 0.3, transparent: true, opacity: 0.9 })
      );
    }
    scene.add(mesh);
    return { mesh, ...d };
  });

  // ── Particles ───────────────────────────────────
  const N = 900;
  const pos = new Float32Array(N * 3);
  const col = new Float32Array(N * 3);
  const palette = [new THREE.Color(0x6366f1), new THREE.Color(0x8b5cf6), new THREE.Color(0x22d3ee), new THREE.Color(0xa855f7)];
  for (let i = 0; i < N; i++) {
    const rr = 9 + Math.random() * 14;
    const theta = Math.random() * Math.PI * 2;
    const phi = Math.acos(2 * Math.random() - 1);
    pos[i*3] = rr * Math.sin(phi) * Math.cos(theta);
    pos[i*3+1] = rr * Math.sin(phi) * Math.sin(theta);
    pos[i*3+2] = rr * Math.cos(phi);
    const c = palette[Math.floor(Math.random() * palette.length)];
    col[i*3] = c.r; col[i*3+1] = c.g; col[i*3+2] = c.b;
  }
  const pGeo = new THREE.BufferGeometry();
  pGeo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
  pGeo.setAttribute('color',    new THREE.BufferAttribute(col, 3));
  const particles = new THREE.Points(pGeo, new THREE.PointsMaterial({ size: 0.06, vertexColors: true, transparent: true, opacity: 0.75 }));
  scene.add(particles);

  // ── Lights ──────────────────────────────────────
  scene.add(new THREE.AmbientLight(0x404060, 3));
  const L1 = new THREE.PointLight(0x6366f1, 5, 30); L1.position.set(6, 6, 6);   scene.add(L1);
  const L2 = new THREE.PointLight(0x22d3ee, 3, 25); L2.position.set(-6, -4, 4); scene.add(L2);

  // ── Mouse ───────────────────────────────────────
  let mx = 0, my = 0;
  window.addEventListener('mousemove', e => {
    mx = (e.clientX / innerWidth)  * 2 - 1;
    my = -(e.clientY / innerHeight) * 2 + 1;
  });

  // ── Animate ─────────────────────────────────────
  let t = 0;
  const animate = () => {
    requestAnimationFrame(animate);
    t += 0.004;

    icoGroup.rotation.x = t * 0.38;
    icoGroup.rotation.y = t * 0.6;

    r1.rotation.z = t * 0.28;
    r2.rotation.x = Math.PI * 0.55 + t * 0.18;
    r2.rotation.z = t * 0.12;
    r3.rotation.y = t * 0.35;

    sats.forEach(s => {
      const a = t * s.s + s.p;
      (s.mesh as THREE.Object3D).position.set(
        Math.cos(a) * s.r,
        Math.sin(a * 0.65) * s.r * 0.5,
        Math.sin(a) * s.r * 0.7
      );
      (s.mesh as THREE.Object3D).rotation.x += 0.012;
      (s.mesh as THREE.Object3D).rotation.y += 0.018;
    });

    particles.rotation.y = t * 0.08;
    particles.rotation.x = t * 0.04;

    camera.position.x += (mx * 2.5 - camera.position.x) * 0.035;
    camera.position.y += (my * 1.8 - camera.position.y) * 0.035;
    camera.lookAt(0, 0, 0);

    L1.position.x = Math.sin(t * 0.7) * 8;
    L1.position.y = Math.cos(t * 0.5) * 6;
    L2.position.x = Math.cos(t * 0.6) * 7;
    L2.position.y = Math.sin(t * 0.8) * 5;

    renderer.render(scene, camera);
  };
  animate();
</script>
