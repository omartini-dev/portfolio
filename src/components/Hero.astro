---
---

<section id="home" class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-16">

  <!-- Particle canvas (covers full hero) -->
  <canvas id="particles-canvas" class="absolute inset-0 w-full h-full pointer-events-none" style="opacity: 0.5;"></canvas>

  <!-- Gradient orbs -->
  <div class="absolute top-0 right-0 w-[900px] h-[900px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(99,102,241,0.14) 0%, transparent 60%); transform: translate(40%,-40%); animation: floatShape 10s ease-in-out infinite; --rot:0deg;">
  </div>
  <div class="absolute bottom-0 left-0 w-[700px] h-[700px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(139,92,246,0.1) 0%, transparent 60%); transform: translate(-40%,40%); animation: floatShape 14s ease-in-out 2s infinite; --rot:0deg;">
  </div>
  <div class="absolute top-1/2 left-1/2 w-[500px] h-[500px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(34,211,238,0.05) 0%, transparent 60%); transform: translate(-50%,-50%);">
  </div>

  <!-- Floating geometric shapes -->
  <div class="absolute top-1/4 right-[22%] w-28 h-28 border border-indigo-500/10 pointer-events-none"
    style="animation: floatShape 9s ease-in-out infinite; --rot:45deg; transform: rotate(45deg);">
  </div>
  <div class="absolute top-[68%] right-[35%] w-16 h-16 border border-violet-500/10 pointer-events-none"
    style="animation: floatShape 12s ease-in-out 3s infinite; --rot:-12deg; transform: rotate(-12deg);">
  </div>
  <div class="absolute top-[30%] left-[8%] w-10 h-10 border border-cyan-400/10 pointer-events-none"
    style="animation: floatShape 11s ease-in-out 1.5s infinite; --rot:20deg; transform: rotate(20deg);">
  </div>
  <div class="absolute top-[55%] left-[20%] w-5 h-5 bg-indigo-500/10 rounded-full pointer-events-none"
    style="animation: floatShape 8s ease-in-out 0.5s infinite; --rot:0deg;">
  </div>
  <div class="absolute top-[15%] right-[10%] w-3 h-3 bg-violet-400/20 rounded-full pointer-events-none"
    style="animation: floatShape 7s ease-in-out 2s infinite; --rot:0deg;">
  </div>

  <!-- Dot grid overlay -->
  <div class="absolute inset-0 dot-grid opacity-40 pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6 w-full py-20 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-16 items-center">

      <!-- Left: Content -->
      <div class="lg:col-span-3 space-y-8">

        <!-- Badge -->
        <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full border border-emerald-500/20 bg-emerald-500/5 text-emerald-400 text-sm font-medium"
          style="animation: fadeIn 0.8s ease-out forwards;">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          Available for new projects
        </div>

        <!-- Name -->
        <div style="animation: fadeUp 0.8s ease-out 0.15s both;">
          <h1 class="font-black leading-none tracking-tight">
            <span class="block text-5xl md:text-7xl xl:text-8xl text-white">Osvaldo</span>
            <span class="block text-5xl md:text-7xl xl:text-8xl gradient-text-animated">Martini</span>
          </h1>
          <p class="mt-5 text-lg md:text-xl text-zinc-400 font-medium tracking-wide">
            Senior Frontend Engineer & Studio Founder
          </p>
        </div>

        <!-- Description -->
        <p class="text-zinc-400 text-lg leading-relaxed max-w-xl" style="animation: fadeUp 0.8s ease-out 0.3s both;">
          11+ years building high-performance marketing websites for B2B SaaS companies.
          Specializing in <span class="text-white font-medium">Astro</span>,
          <span class="text-white font-medium">Next.js</span>, and
          <span class="text-white font-medium">headless CMS</span> architectures
          that score 100 on Lighthouse and actually convert.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4" style="animation: fadeUp 0.8s ease-out 0.45s both;">
          <a href="#work" class="btn-primary text-base">
            View My Work
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#contact" class="btn-secondary text-base">Get In Touch ↗</a>
        </div>

        <!-- Social links -->
        <div class="flex flex-wrap items-center gap-6 text-sm text-zinc-500" style="animation: fadeUp 0.8s ease-out 0.6s both;">
          <a href="mailto:osvaldo.martini.dev@gmail.com" class="hover:text-zinc-300 transition-colors flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>
            Email
          </a>
          <a href="https://linkedin.com/in/osvaldo-martini-bb830b40b/" target="_blank" rel="noopener" class="hover:text-zinc-300 transition-colors flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
            LinkedIn
          </a>
          <a href="https://github.com/omartini-dev" target="_blank" rel="noopener" class="hover:text-zinc-300 transition-colors flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.49.5.09.68-.22.68-.48v-1.69c-2.78.6-3.37-1.34-3.37-1.34-.45-1.15-1.11-1.46-1.11-1.46-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.56 9.56 0 0112 6.8c.85 0 1.71.12 2.51.34 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.93.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10.01 10.01 0 0022 12c0-5.52-4.48-10-10-10z"/></svg>
            GitHub
          </a>
          <span class="flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            Berlin, Germany
          </span>
        </div>
      </div>

      <!-- Right: Terminal with float + shimmer -->
      <div class="lg:col-span-2 hidden lg:block" style="animation: floatShape 8s ease-in-out infinite; --rot:0deg;">
        <div class="terminal relative overflow-hidden">
          <!-- Shimmer sweep -->
          <div class="absolute inset-0 pointer-events-none z-10"
            style="background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.03) 50%, transparent 60%); animation: shimmer 4s ease infinite;">
          </div>
          <div class="terminal-header">
            <div class="terminal-dot" style="background:#ff5f57"></div>
            <div class="terminal-dot" style="background:#febc2e"></div>
            <div class="terminal-dot" style="background:#28c840"></div>
            <span class="ml-3 text-xs text-zinc-500 font-mono">astro build</span>
          </div>
          <div class="terminal-body">
            <div><span class="t-prompt">$</span> <span class="t-cmd">astro build</span></div>
            <div class="t-dim">▶ Running build jobs...</div>
            <br/>
            <div><span class="t-success">✔</span> <span class="t-info">Generating 47 pages</span>&nbsp;&nbsp;<span class="t-dim">0.4s</span></div>
            <div><span class="t-success">✔</span> <span class="t-info">Optimizing assets</span>&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-dim">0.2s</span></div>
            <div><span class="t-success">✔</span> <span class="t-info">TypeScript: strict</span>&nbsp;&nbsp;&nbsp;<span class="t-dim">pass</span></div>
            <div><span class="t-success">✔</span> <span class="t-info">Bundle: 11KB total</span>&nbsp;&nbsp;<span class="t-dim">↓ 94%</span></div>
            <br/>
            <div class="t-dim">── Lighthouse ─────────────</div>
            <div><span class="t-score">Performance </span>&nbsp;&nbsp;<span class="t-success">100</span>&nbsp;<span class="t-success">██████████</span></div>
            <div><span class="t-score">Accessibility</span>&nbsp;<span class="t-success">100</span>&nbsp;<span class="t-success">██████████</span></div>
            <div><span class="t-score">Best Practice</span>&nbsp;<span class="t-success">100</span>&nbsp;<span class="t-success">██████████</span></div>
            <div><span class="t-score">SEO&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>&nbsp;<span class="t-success">100</span>&nbsp;<span class="t-success">██████████</span></div>
            <br/>
            <div><span class="t-highlight">LCP </span>&nbsp;&nbsp;<span class="t-cmd">0.31s</span>&nbsp;&nbsp;<span class="t-success">●</span></div>
            <div><span class="t-highlight">FID </span>&nbsp;&nbsp;<span class="t-cmd">0ms&nbsp;&nbsp;</span>&nbsp;&nbsp;<span class="t-success">●</span></div>
            <div><span class="t-highlight">CLS </span>&nbsp;&nbsp;<span class="t-cmd">0.00 </span>&nbsp;&nbsp;<span class="t-success">●</span></div>
            <br/>
            <div class="t-success">✓ Build complete in 0.8s<span style="animation: blink 1.2s step-end infinite; color:#6366f1">_</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Animated stats bar -->
    <div class="mt-20 pt-8 border-t border-zinc-800/60 grid grid-cols-2 md:grid-cols-4 gap-8"
      style="animation: fadeUp 0.8s ease-out 0.75s both;">
      <div>
        <div class="text-3xl font-black text-white" data-count="11" data-suffix="+">0+</div>
        <div class="text-sm text-zinc-500 mt-1">Years Experience</div>
      </div>
      <div>
        <div class="text-3xl font-black text-white" data-count="30" data-suffix="+">0+</div>
        <div class="text-sm text-zinc-500 mt-1">Projects Delivered</div>
      </div>
      <div>
        <div class="text-3xl font-black text-white" data-count="100" data-suffix="">0</div>
        <div class="text-sm text-zinc-500 mt-1">Lighthouse Scores</div>
      </div>
      <div>
        <div class="text-3xl font-black text-white" data-count="3" data-suffix="">0</div>
        <div class="text-sm text-zinc-500 mt-1">Industries Served</div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>
