---
const projects = [
  {
    name: '9fin',
    url: '9fin.com',
    tagline: 'Financial Intelligence Platform',
    description:
      'High-performance marketing website for the leading debt capital markets intelligence platform. Built data-driven content pages, editorial CMS workflows with Sanity, and real-time data visualizations for a global fintech audience.',
    stack: ['Next.js', 'Sanity', 'TypeScript', 'Tailwind CSS'],
    color: '#3b82f6',
    initial: '9',
    category: 'Fintech · B2B SaaS',
    metrics: ['LCP < 1.2s', 'SEO 100', '+22% organic traffic'],
    screenshot: '/projects/9fin.png',
    contributions: '/projects/9fin_contributions.png',
  },
  {
    name: 'EiQ',
    url: 'eiq.com',
    tagline: 'Energy Intelligence & Analytics',
    description:
      'Marketing website and content hub for an energy data analytics platform. Architected a scalable content model in Sanity supporting multiple editorial teams, with SSG pages delivering sub-second load times.',
    stack: ['Next.js', 'Sanity', 'TypeScript', 'Tailwind CSS'],
    color: '#22c55e',
    initial: 'E',
    category: 'Energy · Enterprise',
    metrics: ['Core Web Vitals pass', 'SSG', '+18% CTR'],
    screenshot: '/projects/eiq.png',
    contributions: '/projects/eiq_contributions.png',
  },
  {
    name: 'Materialize',
    url: 'materialize.com',
    tagline: 'Streaming SQL & Live Data Platform',
    description:
      'Full redesign and rebuild of the marketing site for a real-time streaming SQL platform. Implemented a component-driven design system in Svelte, authored developer-facing documentation pages, and shipped A/B tested landing pages.',
    stack: ['Svelte', 'Sanity', 'TypeScript', 'Tailwind CSS'],
    color: '#a855f7',
    initial: 'M',
    category: 'Data · B2B SaaS',
    metrics: ['+30% conversion', 'Design system', '0 regressions'],
    screenshot: '/projects/materialized.png',
    contributions: '/projects/materialize_contributions.png',
  },
  {
    name: 'Shep',
    url: 'shep.io',
    tagline: 'AI-Powered Customer Support',
    description:
      'Rebuilt the marketing website from scratch with a strong focus on conversion rate optimization and Core Web Vitals. Introduced reusable section components and deep CMS integration for rapid campaign landing pages.',
    stack: ['Astro', 'Sanity', 'TypeScript', 'Tailwind CSS'],
    color: '#f97316',
    initial: 'S',
    category: 'AI · SaaS',
    metrics: ['Performance 100', 'LCP 0.4s', '+25% leads'],
    screenshot: '/projects/shep.png',
    contributions: '/projects/shep_contributions.png',
  },
  {
    name: 'Modus',
    url: 'moduscreate.com',
    tagline: 'Enterprise Technology Consulting',
    description:
      'Component library and marketing platform rebuild for a global technology consultancy. Delivered a scalable design system with 40+ components, and migrated the legacy WordPress site to a headless CMS architecture.',
    stack: ['Next.js', 'Sanity', 'TypeScript', 'Tailwind CSS'],
    color: '#06b6d4',
    initial: 'M',
    category: 'Consulting · Enterprise',
    metrics: ['40+ components', 'Headless CMS', '−40% build time'],
    screenshot: '/projects/modus.png',
    contributions: '/projects/modus_contributions.png',
  },
  {
    name: 'Webstacks',
    url: 'webstacks.com',
    tagline: 'B2B Marketing Website Agency',
    description:
      "Agency's own marketing website and component platform, serving as a blueprint for all client deliverables. Performance-first architecture used as a reference implementation for Lighthouse 100 across all four categories.",
    stack: ['Next.js', 'Sanity', 'TypeScript', 'Tailwind CSS'],
    color: '#e879f9',
    initial: 'W',
    category: 'Agency · Studio',
    metrics: ['Lighthouse 100', 'SSG', 'Reference build'],
    screenshot: '/projects/webstacks.png',
    contributions: '/projects/webstacks_contributions.png',
  },
];
---

<section id="work" class="py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="reveal flex flex-wrap items-end justify-between gap-6 mb-16">
      <div>
        <div class="section-label">Selected Work</div>
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight">
          Real projects,<br/>
          <span class="gradient-text">real results.</span>
        </h2>
      </div>
      <p class="text-zinc-500 max-w-sm text-sm leading-relaxed">
        Client work across fintech, energy, SaaS, and enterprise — all built for performance, SEO, and editorial experience.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      {projects.map((p, i) => (
        <a
          href={`https://${p.url}`}
          target="_blank"
          rel="noopener noreferrer"
          class={`reveal reveal-delay-${(i % 2) + 1} project-card block`}
          data-color={p.color}
        >
          <article class="card overflow-hidden group flex flex-col h-full relative">
            <!-- Spotlight -->
            <div class="spotlight" style={`--spotlight-color: ${p.color};`}></div>

            <!-- Top accent bar -->
            <div class="h-1 w-full" style={`background: linear-gradient(90deg, ${p.color}, ${p.color}44);`}></div>

            <!-- Project screenshot: navigates via card link -->
            <div class="relative overflow-hidden" style="height: 320px;">
              <img
                src={p.screenshot}
                alt={`${p.name} website`}
                class="w-full h-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-[1.02]"
                loading="lazy"
              />
              <div class="absolute inset-0 transition-opacity duration-500" style="background: linear-gradient(to bottom, transparent 50%, var(--bg-card) 100%);"></div>
              <div
                class="absolute top-3 left-3 text-[11px] font-mono px-2.5 py-1 rounded-full backdrop-blur-sm"
                style={`background: ${p.color}20; color: ${p.color}; border: 1px solid ${p.color}45;`}
              >
                {p.url}
              </div>
              <!-- Arrow hint on hover -->
              <div class="absolute top-3 right-3 w-8 h-8 rounded-lg flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-1 group-hover:translate-x-0 backdrop-blur-sm"
                style={`background: ${p.color}25; border: 1px solid ${p.color}45;`}>
                <svg width="13" height="13" viewBox="0 0 12 12" fill="none">
                  <path d="M2 10L10 2M10 2H4M10 2V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style={`color: ${p.color};`}/>
                </svg>
              </div>
            </div>

            <!-- Contributions: stopPropagation → lightbox only -->
            <div
              class="contributions-expand relative overflow-hidden cursor-zoom-in border-t border-zinc-800/60"
              data-src={p.contributions}
              data-label={`${p.name} — GitHub contributions`}
              style="height: 130px;"
            >
              <img
                src={p.contributions}
                alt={`${p.name} contributions`}
                class="w-full h-full object-cover"
                style="object-position: 38% 22%;"
                loading="lazy"
              />
              <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 0%, transparent 30%, var(--bg-card) 100%);"></div>
              <div class="absolute bottom-2.5 left-3 flex items-center gap-1.5">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" class="text-zinc-500">
                  <path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.49.5.09.68-.22.68-.48v-1.69c-2.78.6-3.37-1.34-3.37-1.34-.45-1.15-1.11-1.46-1.11-1.46-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.56 9.56 0 0112 6.8c.85 0 1.71.12 2.51.34 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.93.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10.01 10.01 0 0022 12c0-5.52-4.48-10-10-10z"/>
                </svg>
                <span class="text-[10px] font-mono text-zinc-500">omartini-dev · commits</span>
              </div>
              <!-- Zoom icon -->
              <div class="contributions-zoom absolute top-2.5 right-3 w-7 h-7 rounded-lg flex items-center justify-center opacity-0 transition-all duration-250 backdrop-blur-sm bg-zinc-900/70 border border-zinc-700/60">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-zinc-400">
                  <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
                </svg>
              </div>
            </div>

            <!-- Content -->
            <div class="p-6 flex flex-col flex-1 relative z-10">
              <div class="flex items-start justify-between gap-4 mb-5">
                <div class="flex items-center gap-3">
                  <div
                    class="w-11 h-11 rounded-xl flex items-center justify-center text-sm font-black flex-shrink-0"
                    style={`background: ${p.color}15; color: ${p.color}; border: 1px solid ${p.color}30;`}
                  >
                    {p.initial}
                  </div>
                  <div>
                    <div class="text-white font-bold text-base">{p.name}</div>
                    <div class="text-zinc-600 text-xs">{p.category}</div>
                  </div>
                </div>
                <span class="text-zinc-500 group-hover:text-white transition-colors duration-300 flex-shrink-0 mt-1.5" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 12 12" fill="none">
                    <path d="M2 10L10 2M10 2H4M10 2V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>

              <p class="text-zinc-300 text-sm mb-2 font-semibold">{p.tagline}</p>
              <p class="text-zinc-500 text-sm leading-relaxed flex-1">{p.description}</p>

              <div class="flex flex-wrap gap-2 my-4">
                {p.metrics.map((m) => (
                  <span
                    class="text-xs px-2.5 py-1 rounded-full font-medium"
                    style={`background: ${p.color}10; color: ${p.color}; border: 1px solid ${p.color}25;`}
                  >
                    {m}
                  </span>
                ))}
              </div>

              <div class="flex flex-wrap gap-1.5 pt-4 border-t border-zinc-800/60">
                {p.stack.map((t) => (
                  <span class="tech-badge-glow" style="font-size:11px;">{t}</span>
                ))}
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center p-4" style="background: rgba(0,0,0,0.92);">
  <button id="lightbox-close" class="absolute top-5 right-5 w-10 h-10 rounded-full bg-zinc-800/80 border border-zinc-700 flex items-center justify-center text-zinc-400 hover:text-white hover:bg-zinc-700 transition-colors backdrop-blur-sm">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M18 6L6 18M6 6l12 12"/>
    </svg>
  </button>
  <div class="text-zinc-500 text-xs font-mono absolute top-6 left-1/2 -translate-x-1/2 tracking-wider" id="lightbox-label"></div>
  <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[88vh] rounded-xl border border-zinc-800/60 shadow-2xl object-contain" style="opacity:0; transition: opacity 0.25s ease;" />
</div>

<script>
  // ── Lightbox ────────────────────────────────────────────────────────
  const lb      = document.getElementById('lightbox')!;
  const lbImg   = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbLabel = document.getElementById('lightbox-label')!;
  const lbClose = document.getElementById('lightbox-close')!;

  const openLb = (src: string, label: string) => {
    lbImg.style.opacity = '0';
    lbImg.src = src;
    lbLabel.textContent = label;
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    lbImg.onload = () => { lbImg.style.opacity = '1'; };
  };

  const closeLb = () => {
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    lbImg.src = '';
  };

  lbClose.addEventListener('click', closeLb);
  lb.addEventListener('click', e => { if (e.target === lb) closeLb(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLb(); });

  // Contributions: expand to lightbox, don't navigate
  document.querySelectorAll<HTMLElement>('.contributions-expand').forEach(el => {
    el.addEventListener('click', e => {
      e.preventDefault();
      e.stopPropagation();
      openLb(el.dataset.src ?? '', el.dataset.label ?? '');
    });
  });

  // ── Premium hover: lift + colored shadow + border glow ──────────────
  document.querySelectorAll<HTMLElement>('.project-card').forEach(card => {
    const color   = card.dataset.color ?? '#6366f1';
    const article = card.querySelector<HTMLElement>('article')!;

    card.addEventListener('mouseenter', () => {
      article.style.boxShadow   = `0 28px 72px -8px ${color}28, 0 0 0 1px ${color}35`;
      article.style.borderColor = `${color}45`;
    });
    card.addEventListener('mouseleave', () => {
      article.style.boxShadow   = '';
      article.style.borderColor = '';
    });

    // Spotlight tracking
    card.addEventListener('mousemove', e => {
      const r = card.getBoundingClientRect();
      article.style.setProperty('--gx', `${(e.clientX - r.left) / r.width  * 100}%`);
      article.style.setProperty('--gy', `${(e.clientY - r.top)  / r.height * 100}%`);
    });
  });
</script>

<style>
  .project-card {
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .project-card:hover {
    transform: translateY(-8px);
  }
  .project-card article {
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }
  .contributions-expand:hover .contributions-zoom {
    opacity: 1;
  }
</style>
