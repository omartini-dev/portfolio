---
const projects = [
  {
    name: '9fin',
    url: '9fin.com',
    tagline: 'Financial Intelligence Platform',
    description:
      'High-performance marketing website for the leading debt capital markets intelligence platform. Built data-driven content pages, editorial CMS workflows with Sanity, and real-time data visualizations for a global fintech audience.',
    stack: ['Next.js', 'Sanity', 'TypeScript', 'Tailwind CSS'],
    color: '#3b82f6',
    initial: '9',
    category: 'Fintech · B2B SaaS',
    metrics: ['LCP < 1.2s', 'SEO 100', '+22% organic traffic'],
    screenshot: '/projects/9fin.png',
  },
  {
    name: 'EiQ',
    url: 'eiq.com',
    tagline: 'Energy Intelligence & Analytics',
    description:
      'Marketing website and content hub for an energy data analytics platform. Architected a scalable content model in Sanity supporting multiple editorial teams, with SSG pages delivering sub-second load times.',
    stack: ['Next.js', 'Sanity', 'TypeScript', 'Tailwind CSS'],
    color: '#22c55e',
    initial: 'E',
    category: 'Energy · Enterprise',
    metrics: ['Core Web Vitals pass', 'SSG', '+18% CTR'],
    screenshot: '/projects/eiq.png',
  },
  {
    name: 'Materialize',
    url: 'materialize.com',
    tagline: 'Streaming SQL & Live Data Platform',
    description:
      'Full redesign and rebuild of the marketing site for a real-time streaming SQL platform. Implemented a component-driven design system in Svelte, authored developer-facing documentation pages, and shipped A/B tested landing pages.',
    stack: ['Svelte', 'Sanity', 'TypeScript', 'Tailwind CSS'],
    color: '#a855f7',
    initial: 'M',
    category: 'Data · B2B SaaS',
    metrics: ['+30% conversion', 'Design system', '0 regressions'],
    screenshot: '/projects/materialized.png',
  },
  {
    name: 'Shep',
    url: 'shep.io',
    tagline: 'AI-Powered Customer Support',
    description:
      'Rebuilt the marketing website from scratch with a strong focus on conversion rate optimization and Core Web Vitals. Introduced reusable section components and deep CMS integration for rapid campaign landing pages.',
    stack: ['Astro', 'Sanity', 'TypeScript', 'Tailwind CSS', 'Vercel'],
    color: '#f97316',
    initial: 'S',
    category: 'AI · SaaS',
    metrics: ['Performance 100', 'LCP 0.4s', '+25% leads'],
    screenshot: '/projects/shep.png',
  },
  {
    name: 'Modus',
    url: 'moduscreate.com',
    tagline: 'Enterprise Technology Consulting',
    description:
      'Component library and marketing platform rebuild for a global technology consultancy. Delivered a scalable design system with 40+ components, and migrated the legacy WordPress site to a headless CMS architecture.',
    stack: ['Next.js', 'Sanity', 'TypeScript', 'Tailwind CSS'],
    color: '#06b6d4',
    initial: 'M',
    category: 'Consulting · Enterprise',
    metrics: ['40+ components', 'Headless CMS', '−40% build time'],
    screenshot: '/projects/modus.png',
  },
  {
    name: 'Webstacks',
    url: 'webstacks.com',
    tagline: 'B2B Marketing Website Agency',
    description:
      "Agency's own marketing website and component platform, serving as a blueprint for all client deliverables. Performance-first architecture used as a reference implementation for Lighthouse 100 across all four categories.",
    stack: ['Next.js', 'Sanity', 'TypeScript', 'Tailwind CSS'],
    color: '#e879f9',
    initial: 'W',
    category: 'Agency · Studio',
    metrics: ['Lighthouse 100', 'SSG', 'Reference build'],
    screenshot: '/projects/webstacks.png',
  },
];
---

<section id="work" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="reveal flex flex-wrap items-end justify-between gap-6 mb-16">
      <div>
        <div class="section-label">Selected Work</div>
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight">
          Real projects,<br/>
          <span class="gradient-text">real results.</span>
        </h2>
      </div>
      <p class="text-zinc-500 max-w-sm text-sm leading-relaxed">
        Client work across fintech, energy, SaaS, and enterprise — all built for performance, SEO, and editorial experience.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((p, i) => (
        <div class={`reveal reveal-delay-${(i % 3) + 1} tilt-card`} data-tilt="10">
        <article
          class="tilt-inner card overflow-hidden group flex flex-col h-full relative cursor-pointer"
        >
          <!-- Full-card link overlay -->
          <a
            href={`https://${p.url}`}
            target="_blank"
            rel="noopener noreferrer"
            class="absolute inset-0 z-20"
            aria-label={`Visit ${p.name}`}
          ></a>

          <!-- Spotlight -->
          <div class="spotlight" style={`--spotlight-color: ${p.color};`}></div>

          <!-- Top accent bar -->
          <div class="h-0.5 w-full" style={`background: linear-gradient(90deg, ${p.color}, ${p.color}55);`}></div>

          <!-- Screenshot preview -->
          <div class="relative overflow-hidden" style="height: 160px;">
            <img
              src={p.screenshot}
              alt={`${p.name} website`}
              class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0" style={`background: linear-gradient(to bottom, transparent 40%, #111113 100%);`}></div>
            <div
              class="absolute top-2 right-2 text-[10px] font-mono px-2 py-0.5 rounded-full"
              style={`background: ${p.color}20; color: ${p.color}; border: 1px solid ${p.color}40;`}
            >
              {p.url}
            </div>
          </div>

          <div class="p-6 flex flex-col flex-1 relative z-10">
            <!-- Header -->
            <div class="flex items-start justify-between gap-4 mb-5">
              <div class="flex items-center gap-3">
                <div
                  class="w-10 h-10 rounded-xl flex items-center justify-center text-sm font-black flex-shrink-0"
                  style={`background: ${p.color}15; color: ${p.color}; border: 1px solid ${p.color}30;`}
                >
                  {p.initial}
                </div>
                <div>
                  <div class="text-white font-bold">{p.name}</div>
                  <div class="text-zinc-600 text-xs">{p.category}</div>
                </div>
              </div>
              <span class="text-zinc-600 group-hover:text-white transition-colors flex-shrink-0 mt-1" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 12 12" fill="none">
                  <path d="M2 10L10 2M10 2H4M10 2V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>

            <!-- Content -->
            <p class="text-zinc-500 text-sm mb-1 font-medium">{p.tagline}</p>
            <p class="text-zinc-400 text-sm leading-relaxed flex-1">{p.description}</p>

            <!-- Metrics -->
            <div class="flex flex-wrap gap-2 my-4">
              {p.metrics.map((m) => (
                <span
                  class="text-xs px-2 py-0.5 rounded-full font-medium"
                  style={`background: ${p.color}12; color: ${p.color}; border: 1px solid ${p.color}25;`}
                >
                  {m}
                </span>
              ))}
            </div>

            <!-- Stack -->
            <div class="flex flex-wrap gap-1.5 pt-4 border-t border-zinc-800/60">
              {p.stack.map((t) => (
                <span class="tech-badge-glow" style="font-size:11px;">{t}</span>
              ))}
            </div>
          </div>
        </article>
        </div>
      ))}
    </div>
  </div>
</section>
